# ─── Domain Monitor ───
# Comma-separated list of domains to monitor
MANAGED_DOMAINS=example.com,example.dev

# Optional: fallback for TLDs without public RDAP
WHOISXML_API_KEY=

# ─── Authentication ───
# OIDC toggle: "true" to enable SSO login, "false" to bypass (default)
OIDC_ENABLED=false

# OIDC / Keycloak config (only used when OIDC_ENABLED=true)
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# NextAuth
NEXTAUTH_SECRET=change-me-to-a-random-32-char-string
NEXTAUTH_URL=http://localhost:3000

# ─── RBAC ───
# Admin emails (comma-separated). Admin sees all domains.
ADMIN_EMAILS=

# Local dev fake identity (used when OIDC_ENABLED=false)
DEV_ADMIN_EMAIL=
DEV_USER_EMAIL=
